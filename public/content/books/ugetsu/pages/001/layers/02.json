      "content": [
        {
          "type": "text",
          "text": "At the 荒れ屋敷"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "Toward the hour when "
        },
        {
          "type": "annotated",
          "text": "月の光",
          "reading": "つきのひかり",
          "language": "ja",
          "noteIds": ["note-moonlight"]
        },
        {
          "type": "text",
          "text": " loosened from the clouds, a "
        },
        {
          "type": "annotated",
          "text": "旅人",
          "reading": "たびびと",
          "language": "ja",
          "noteIds": ["note-traveler"]
        },
        {
          "type": "text",
          "text": " came upon an "
        },
        {
          "type": "annotated",
          "text": "荒れ屋敷",
          "reading": "あれやしき",
          "language": "ja",
          "noteIds": ["note-residence"]
        },
        {
          "type": "text",
          "text": ". "
        },
        {
          "type": "annotated",
          "text": "葦",
          "reading": "あし",
          "language": "ja",
          "noteIds": ["note-reeds"]
        },
        {
          "type": "text",
          "text": " brushed the broken gate, and the pale path seemed to remember feet that no longer crossed it."
        }
      ],
      "audioSegments": [
        {
          "id": "segment-01",
          "text": "月の光",
          "start": 1,
          "end": 1
        },
        {
          "id": "segment-02",
          "text": "旅人",
          "start": 3,
          "end": 3
        },
        {
          "id": "segment-03",
          "text": "荒れ屋敷",
          "start": 5,
          "end": 5
        },
        {
          "id": "segment-04",
          "text": "葦",
          "start": 7,
          "end": 7
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "paragraph",
      "content": [
        {
          "type": "text",
          "text": "Within, a "
        },
        {
          "type": "annotated",
          "text": "灯火",
          "reading": "ともしび",
          "language": "ja",
          "noteIds": ["note-lamp"]
        },
        {
          "type": "text",
          "text": " burned with a threadlike flame. The traveler paused at the threshold, hearing no voice, yet feeling an unseen "
        },
        {
          "type": "annotated",
          "text": "気配",
          "reading": "けはい",
          "language": "ja",
          "noteIds": ["note-presence"]
        },
        {
          "type": "text",
          "text": " behind the screens."
        }
      ],
      "audioSegments": [
        {
          "id": "segment-05",
          "text": "灯火",
          "start": 1,
          "end": 1
        },
        {
          "id": "segment-06",
          "text": "気配",
          "start": 3,
          "end": 3
        }
      ]
    }
  ]
}
