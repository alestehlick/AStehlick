{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "bookId", "layers", "pages"],
  "properties": {
    "formatVersion": { "const": 1 },
    "bookId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "label", "description"],
        "properties": {
          "number": { "type": "integer", "minimum": 1, "maximum": 99 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "sequence", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9]{3}$" },
          "title": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "path": { "type": "string", "pattern": "^[^/].*\\.json$" }
        }
      }
    }
  }
}
