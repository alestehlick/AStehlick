{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "layer.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "pageId", "layer", "language", "blocks"],
  "properties": {
    "formatVersion": {
      "const": 1
    },
    "pageId": {
      "type": "string",
      "pattern": "^[0-9]{3}$"
    },
    "layer": {
      "type": "integer",
      "minimum": 1,
      "maximum": 99
    },
    "language": {
      "enum": ["ja", "en", "mixed"]
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/block"
      }
    }
  },
  "$defs": {
    "inline": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {
              "const": "text"
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "emphasis": {
              "enum": ["italic", "strong"]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text", "language", "noteIds"],
          "properties": {
            "type": {
              "const": "annotated"
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "reading": {
              "type": "string",
              "minLength": 1
            },
            "language": {
              "enum": ["ja", "en", "mixed"]
            },
            "noteIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              }
            },
            "emphasis": {
              "enum": ["italic", "strong"]
            },
            "audio": {
              "type": "string",
              "minLength": 1
            },
            "phonographic": {
              "type": "object",
              "additionalProperties": false,
              "required": ["surface", "reading"],
              "properties": {
                "surface": {
                  "type": "string",
                  "minLength": 1
                },
                "reading": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "lineBreak"
            }
          }
        }
      ]
    },
    "audioSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "start", "end"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "content"],
          "properties": {
            "type": {
              "const": "paragraph"
            },
            "content": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/inline"
              }
            },
            "audioSegments": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/audioSegment"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "level", "content"],
          "properties": {
            "type": {
              "const": "heading"
            },
            "level": {
              "type": "integer",
              "minimum": 2,
              "maximum": 4
            },
            "content": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/inline"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "divider"
            }
          }
        }
      ]
    }
  }
}
