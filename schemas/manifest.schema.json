{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "bookId", "pages"],
  "properties": {
    "formatVersion": {
      "const": 1
    },
    "bookId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "sequence", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "path": {
            "type": "string",
            "pattern": "^[^/].*\\.json$"
          }
        }
      }
    }
  }
}
